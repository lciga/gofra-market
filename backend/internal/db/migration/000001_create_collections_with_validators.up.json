[
  { "create": "users", "validator": { "$jsonSchema": {
      "bsonType": "object",
      "required": ["login", "pass_hash", "balance", "created_at"],
      "properties": {
        "login": {"bsonType": "string", "minLength": 1, "maxLength": 64},
        "pass_hash": {"bsonType": "binData"},
        "balance": {"bsonType": "int", "minimum": 0},
        "created_at": {"bsonType": "date"}
      }
    }}},

  { "create": "gofers", "validator": { "$jsonSchema": {
      "bsonType": "object",
      "required": ["ovner_id", "name", "rarity", "created_at"],
      "properties": {
        "ovner_id": {"bsonType": "objectId"},
        "name": {"bsonType": "string", "minLength": 1, "maxLength": 64},
        "rarity": {"bsonType": "int", "minimum": 1, "maximum": 3},
        "created_at": {"bsonType": "date"}
      }
    }}},

  { "create": "listings", "validator": { "$jsonSchema": {
      "bsonType": "object",
      "required": ["gofer_id", "seller_id", "price", "is_sold", "buyer_id", "description", "image", "created_at"],
      "properties": {
        "gofer_id": {"bsonType": "objectId"},
        "seller_id": {"bsonType": "objectId"},
        "price": {"bsonType": "int", "minimum": 0},
        "is_sold": {"bsonType": "bool"},
        "buyer_id": {"bsonType": ["objectId", "null"]},
        "description": {"bsonType": "string", "minLength": 1, "maxLength": 256},
        "image": {"bsonType": ["object", "null"], "properties": {
          "kind": {"bsonType": "string", "enum": ["url", "upload"]},
          "source_url": {"bsonType": ["string", "null"], "pattern": "^https?://.+"},
          "fetched_at": {"bsonType": ["date", "null"]},
          "content_type": {"bsonType": ["string", "null"]},
          "debug_snippet_b64": {"bsonType": ["string", "null"]}
        }},
        "created_at": {"bsonType": "date"}
      }
    }}},

  { "create": "sessions", "validator": { "$jsonSchema": {
      "bsonType": "object",
      "required": ["user_id", "sid", "expires_at"],
      "properties": {
        "user_id": {"bsonType": "objectId"},
        "sid": {"bsonType": "string", "minLength": 16, "maxLength": 64},
        "expires_at": {"bsonType": "date"}
      }
    }}}
]
